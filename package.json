{
  "name": "proyectos-aws-gitlab-monorepo",
  "version": "1.0.0",
  "description": "Monorepo educativo para despliegues AWS desde GitLab CI",
  "private": true,
  "scripts": {
    "prepare": "husky install",
    "lint": "npm run lint:js && npm run lint:html",
    "lint:js": "eslint . --ext .js",
    "lint:html": "htmlhint \"**/*.html\"",
    "format": "prettier --write \"**/*.{js,json,md,html,css,yml}\"",
    "test": "npm run test:d && npm run test:e && npm run test:g && npm run test:h",
    "test:d": "python -m pytest caso-d-serverless-basic/backend/tests/ -v --tb=short",
    "test:e": "python -m pytest caso-e-dynamodb-persistence/backend/tests/ -v --tb=short",
    "test:g": "python -m pytest caso-g-event-driven/backend/tests/ -v --tb=short",
    "test:h": "python -m pytest caso-h-observability/backend/tests/ -v --tb=short"
  },
  "devDependencies": {
    "@commitlint/cli": "^17.0.0",
    "@commitlint/config-conventional": "^17.0.0",
    "eslint": "^8.57.0",
    "htmlhint": "^1.9.1",
    "husky": "^8.0.0",
    "prettier": "^3.0.0",
    "stylelint": "^17.3.0"
  },
  "overrides": {
    "htmlhint": {
      "glob": "^11.0.0"
    }
  }
}